DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
JWT_SIGNING_KEY=change-me-too
DEBUG=True
ALLOWED_HOSTS=*
# Comma-separated. In prod, set these to your real frontend + API domains.
# CORS_ALLOWED_ORIGINS guards browser fetches; CSRF_TRUSTED_ORIGINS is needed
# for the Django admin to accept form POSTs from the API subdomain.
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgres://survey:survey@postgres:5432/survey
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
JWT_ACCESS_LIFETIME_MIN=15
JWT_REFRESH_LIFETIME_DAYS=7
LOG_LEVEL=INFO
# Per-cell encryption for sensitive answers. REQUIRED — generate your own with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key
